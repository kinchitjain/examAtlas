# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=examatlas
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=              # blank = auto (DEBUG in dev, INFO in prod)
LOG_FILE=               # blank = stdout only. e.g. logs/examatlas.log

# Redis (optional — omit or leave blank to disable the Redis layer)
REDIS_URL=redis://localhost:6379/0
BFF_SECRET_KEY=
