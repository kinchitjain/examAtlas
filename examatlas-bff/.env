# ── BFF Server ────────────────────────────────────────────────────────────
BFF_PORT=3000

# ── Backend URL (never exposed to browser) ────────────────────────────────
BACKEND_URL=http://localhost:8000

# ── Secret shared between BFF and FastAPI backend ─────────────────────────
# Add this same value to your FastAPI .env as BFF_SECRET_KEY
# The BFF adds X-BFF-Key: <value> to every backend request.
# FastAPI middleware rejects any request missing this header.
BFF_SECRET_KEY=

# ── JWT signing secret (BFF issues tokens to authenticated clients) ────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── CORS — only allow your frontend origin ────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate limits ───────────────────────────────────────────────────────────
# Search endpoint — expensive LLM calls
RATE_LIMIT_SEARCH_MAX=20
RATE_LIMIT_SEARCH_WINDOW_MS=60000

# General endpoints
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_GENERAL_WINDOW_MS=60000

# ── Optional auth (set to "true" to require JWT on search endpoints) ───────
REQUIRE_AUTH=false
